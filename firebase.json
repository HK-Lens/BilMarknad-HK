{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,

    "ignore": [
      "firebase.json",
      ".firebaserc",

      "**/.*",
      "**/.*/**",

      "**/node_modules/**",
      "**/package.json",
      "**/package-lock.json",
      "**/yarn.lock",
      "**/pnpm-lock.yaml",

      "**/.env",
      "**/.env.*",
      "**/*env*",
      "**/*secret*",
      "**/*private*",
      "**/*credential*",
      "**/*credentials*",
      "**/*serviceAccount*",
      "**/*service-account*",
      "**/*adminsdk*",
      "**/*.pem",
      "**/*.key",
      "**/*.crt",
      "**/*.p12",
      "**/*.pfx",

      "**/firestore.rules",
      "**/storage.rules",
      "**/database.rules.json",
      "**/firestore.indexes.json",

      "**/firebase-debug.log",
      "**/firebase-debug.*.log",
      "**/ui-debug.log",

      "**/README.md",
      "**/CHANGELOG.md",
      "**/LICENSE",
      "**/docs/**",
      "**/notes/**",

      "**/test/**",
      "**/tests/**",
      "**/__tests__/**",
      "**/coverage/**",

      "**/src/**",
      "**/scss/**",
      "**/sass/**",
      "**/less/**",

      "**/*.map",
      "**/*.ts",
      "**/*.tsx",
      "**/*.jsx",

      "**/*.bak",
      "**/*.backup",
      "**/*.old",
      "**/*.tmp",
      "**/*.temp",

      "**/Thumbs.db",
      "**/.DS_Store"
    ],

    "headers": [
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-store, max-age=0"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=()"
          }
        ]
      },

      {
        "source": "**/*.js",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      },

      {
        "source": "**/*.css",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "no-cache, max-age=0, must-revalidate"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      },

      {
        "source": "**/*.{png,jpg,jpeg,webp,avif,svg,gif,ico}",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public, max-age=604800"
          },
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          }
        ]
      },

      {
        "source": "**/*",
        "headers": [
          {
            "key": "X-Content-Type-Options",
            "value": "nosniff"
          },
          {
            "key": "X-Frame-Options",
            "value": "SAMEORIGIN"
          },
          {
            "key": "Referrer-Policy",
            "value": "strict-origin-when-cross-origin"
          },
          {
            "key": "Permissions-Policy",
            "value": "camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), accelerometer=(), gyroscope=(), magnetometer=()"
          },
          {
            "key": "Content-Security-Policy",
            "value": "default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'self'; img-src 'self' data: blob: https://firebasestorage.googleapis.com https://*.googleusercontent.com https://*.gstatic.com; font-src 'self' data: https://fonts.gstatic.com https://cdnjs.cloudflare.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' https://www.gstatic.com https://www.googleapis.com https://apis.google.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.firebasestorage.app https://firebasestorage.googleapis.com https://identitytoolkit.googleapis.com https://securetoken.googleapis.com https://firestore.googleapis.com https://firebaseinstallations.googleapis.com https://firebaseappcheck.googleapis.com; frame-src 'self' https://*.firebaseapp.com https://accounts.google.com; form-action 'self'; upgrade-insecure-requests"
          }
        ]
      }
    ]
  }
}
